{
  "name": "@palinc/nirnam",
  "version": "1.3.0",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.esm.js",
  "types": "dist/index.d.ts",
  "unpkg": "dist/index.umd.js",
  "jsdelivr": "dist/index.umd.js",
  "exports": {
    ".": {
      "import": "./dist/index.esm.js",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./mcp": {
      "import": "./dist/mcp.esm.js",
      "require": "./dist/mcp.js",
      "types": "./dist/mcp.d.ts"
    },
    "./react": {
      "import": "./dist/react.esm.js",
      "require": "./dist/react.js",
      "types": "./dist/react.d.ts"
    },
    "./angular": {
      "import": "./dist/angular.esm.js",
      "require": "./dist/angular.js",
      "types": "./dist/angular.d.ts"
    },
    "./agents": {
      "import": "./dist/agents.esm.js",
      "require": "./dist/agents.js",
      "types": "./dist/agents.d.ts"
    },
    "./agents/react": {
      "import": "./dist/agents-react.esm.js",
      "require": "./dist/agents-react.js",
      "types": "./dist/agents-react.d.ts"
    },
    "./agents/testing": {
      "import": "./dist/agents-testing.esm.js",
      "require": "./dist/agents-testing.js",
      "types": "./dist/agents-testing.d.ts"
    },
    "./vite": {
      "import": "./dist/vite.esm.js",
      "require": "./dist/vite.js",
      "types": "./dist/vite.d.ts"
    },
    "./rsbuild": {
      "import": "./dist/rsbuild.esm.js",
      "require": "./dist/rsbuild.js",
      "types": "./dist/rsbuild.d.ts"
    },
    "./webpack": {
      "import": "./dist/webpack.esm.js",
      "require": "./dist/webpack.js",
      "types": "./dist/webpack.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "rollup -c",
    "build:watch": "rollup -c -w",
    "clean": "rimraf dist",
    "prebuild": "npm run clean",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "lint": "eslint",
    "commit": "git-cz",
    "commitlint": "commitlint --edit"
  },
  "keywords": [
    "shared-worker",
    "broadcast-channel",
    "message-bus",
    "micro-frontend",
    "mfe",
    "pub-sub",
    "request-reply",
    "mcp",
    "agents"
  ],
  "author": "Shaurya Singh Pal",
  "license": "ISC",
  "description": "A three-layer hybrid message bus for micro-frontend communication using SharedWorker and BroadcastChannel",
  "peerDependencies": {
    "@modelcontextprotocol/sdk": ">=1.0.0",
    "@rsbuild/core": ">=1",
    "react": ">=17",
    "rxjs": ">=6",
    "vite": ">=4",
    "webpack": ">=5"
  },
  "peerDependenciesMeta": {
    "@modelcontextprotocol/sdk": {
      "optional": true
    },
    "@rsbuild/core": {
      "optional": true
    },
    "react": {
      "optional": true
    },
    "rxjs": {
      "optional": true
    },
    "vite": {
      "optional": true
    },
    "webpack": {
      "optional": true
    }
  },
  "devDependencies": {
    "@commitlint/cli": "^18.0.0",
    "@commitlint/config-conventional": "^18.0.0",
    "@rollup/plugin-commonjs": "^25.0.0",
    "@rollup/plugin-node-resolve": "^15.0.0",
    "@rollup/plugin-terser": "^0.4.0",
    "@rollup/plugin-typescript": "^11.0.0",
    "@semantic-release/changelog": "^6.0.0",
    "@semantic-release/git": "^10.0.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.1.0",
    "@types/react": "^18.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "fake-indexeddb": "^6.2.5",
    "globals": "^15.0.0",
    "husky": "^9.0.0",
    "jest": "^30.0.5",
    "react": "^18.0.0",
    "rimraf": "^5.0.0",
    "rollup": "^4.0.0",
    "rollup-plugin-dts": "^6.0.0",
    "rxjs": "^7.0.0",
    "semantic-release": "^24.0.0",
    "ts-jest": "^29.4.0",
    "typescript": "^5.8.3"
  },
  "publishConfig": {
    "access": "public"
  }
}
